# EditorConfig is universal: supported by VS Code, Visual Studio, Rider, vim, emacs, opencode, and CI tools.
# https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{csproj,sln,slnx,xml,yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sh]
end_of_line = lf
indent_size = 2

[*.ps1]
end_of_line = crlf
