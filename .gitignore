# Whitelist pattern: block everything by default, then unblock specific paths.
# This prevents accidentally tracking stray files (build artifacts, IDE files, temp files).
/*
!/.gitignore
!/.gitattributes
!.editorconfig
!/.github/
!/.github/**
!/LICENSE
!/*.md
!/docs/
!/docs/*
!/src/
!/src/**/*
!/tools/
!/tools/**/*
!/samples/
!/samples/**
!/scripts/
!/scripts/**
!/tests/
!/tests/**

# Sub-blacklists — re-block specific paths within whitelisted directories
bin/
obj/
*.dll
*.so
*.dylib
*.exe
*.pdb
*.ithmb
!/tests/samples/**/*.ithmb
/samples/*
!/samples/synthetic/
!/samples/synthetic/**
docs/*.mmd

.vscode/
.idea/
*.user
*.suo
*.DotSettings.user
*.log





# Privacy blacklists
PERFORMANCE.md
tools/validate_reuhno_samples.sh
tools/IthmbBenchmark/
