<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm64;osx-arm64</RuntimeIdentifiers>

    <!-- Native shared library produced by Native AOT for the v10 codec plugin ABI. -->
    <OutputType>Library</OutputType>
    <PublishAot>true</PublishAot>
    <NativeLib>Shared</NativeLib>
    <SelfContained>true</SelfContained>

    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <DisableRuntimeMarshalling>true</DisableRuntimeMarshalling>

    <!-- Resulting binary name MUST match the manifest's "executable" field. -->
    <AssemblyName>IthmbCodec</AssemblyName>
    <RootNamespace>IthmbCodec</RootNamespace>

    <!-- Exclude the test project from main compilation. -->
    <DefaultItemExcludes>$(DefaultItemExcludes);test/**</DefaultItemExcludes>

    <!-- This plugin is not part of the ImageGlass app; skip auto-generated AppBuildInfo. -->
    <GenerateIgAppBuildInfo>false</GenerateIgAppBuildInfo>

    <!-- Plugin: do not produce a NuGet package. -->
    <IsPackable>false</IsPackable>

    <!-- Lock NuGet dependency versions for supply-chain integrity -->
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>

    <!-- Enforce deterministic code style during build (using built-in Roslyn analyzers) -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisLevel>latest-recommended</AnalysisLevel>
    <AnalysisMode>AllEnabledByDefault</AnalysisMode>

    <!-- Treat style warnings as errors in CI — opt out per-file with #pragma if needed -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Exclude specific analyzer rules that conflict with Native AOT patterns -->
    <NoWarn>$(NoWarn);CA2007;CA1062;CA1303;CA2101;CA5400</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ImageGlass.SDK" Version="1.0.100266" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="StbImageSharp" Version="2.30.15" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="IthmbCodec.Tests" />
    <InternalsVisibleTo Include="IthmbDecoder" />
    <InternalsVisibleTo Include="IthmbSampleGenerator" />
    <InternalsVisibleTo Include="IthmbCodec.Benchmark" />
  </ItemGroup>

  <ItemGroup>
    <!-- Manifest must sit next to the published .dll so the host can discover the plugin. -->
    <None Update="igplugin.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <None Update="profiles.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
  </ItemGroup>

  <!-- Build provenance embedded in assembly metadata for diagnostics -->
  <Target Name="SetBuildProvenance" BeforeTargets="CoreGenerateAssemblyInfo">
    <ItemGroup>
      <AssemblyMetadata Include="BuildTimestamp" Value="$([System.DateTime]::UtcNow.ToString('yyyy-MM-ddTHH:mm:ssZ'))" />
      <AssemblyMetadata Include="CommitSha" Value="$(GITHUB_SHA)" Condition="'$(GITHUB_SHA)' != ''" />
    </ItemGroup>
  </Target>

</Project>
