// External profile overrides for IthmbCodec.
// Built-in profiles live in IthmbCodecPlugin.ProfilesJson.cs (embedded JSON).
// Add entries here to override built-in profiles or define new ones — no recompile needed.
// This file is loaded on the first decode call; entries here take precedence over embedded.
//
// Schema:
//   prefix: int (format FXXXX, e.g. 1007)
//   width, height: int (pixels)
//   encoding: "rgb565" | "rgb555" | "reorderedrgb555" | "yuv422" | "yuv422clcl" | "yuv422cl" | "ycbcr420"
//   frameBytes: int (bytes per frame, including padding)
//   littleEndian: bool (optional, default true)
//   isPadded: bool (optional, default false)
//   isInterlaced: bool (optional, default false)
//   swapsDimensions: bool (optional, default false)
//   isClcl: bool (optional, default false)
//   isCl: bool (optional, default false)
//   swapChromaPlanes: bool (optional, default false)
//   swapRgbChannels: bool (optional, default false)
//   rotation: int (optional, default 0 — 90/180/270)
//   useMhniDimensions: bool (optional, default false)
//   slotSize: int (optional, default 0 — slot padding for Touch/iPhone)
//   cropX, cropY, cropWidth, cropHeight: int (optional)
//   fallbackEncodings: string[] (optional — e.g. ["rgb555", "reorderedrgb555"])
//
// ── Example: override a built-in profile ──
// Uncomment to change iPod Photo 4G full-screen to different dimensions:
// {"prefix": 1013, "width": 220, "height": 176, "encoding": "rgb565", "frameBytes": 77440, "littleEndian": false}
//
// ── iOpenPod corrections ──
// iOpenPod (verified with real hardware) differs from our built-in defaults in a few places.
// Uncomment these if you want iOpenPod-verified dimensions instead of our defaults:
//
// Profile 1061: iOpenPod says 56x56; we default to 55x55 with UseMhniDimensions fallback.
// {"prefix": 1061, "width": 56, "height": 56, "encoding": "rgb565", "frameBytes": 6272}
//
// Profile 1081: libgpod declares JPEG; iOpenPod confirms RGB565 640x480 (our default).
// Only override if you have a sample that decodes as JPEG.
// {"prefix": 1081, "width": 640, "height": 480, "encoding": "jpeg", "frameBytes": 614400}
//
// ── Nano 7G overrides ──
// Nano 7G repurposes global format IDs with cover-art dimensions.
// These are handled automatically by TryResolveProfile's device override system.
// Uncomment if you want the global profiles to match Nano 7G's dimensions instead:
// {"prefix": 1013, "width": 50, "height": 50, "encoding": "rgb565", "frameBytes": 5000}
// {"prefix": 1015, "width": 58, "height": 58, "encoding": "rgb565", "frameBytes": 6728}
// {"prefix": 1016, "width": 57, "height": 57, "encoding": "rgb565", "frameBytes": 6498}
//
// ── iOS 1.x firmware variants (iPhone 1.x — per Steee29) ──
// libgpod does not distinguish iOS versions. Uncomment for iPhone 1.x targets:
// {"prefix": 3004, "width": 55, "height": 55, "encoding": "rgb555", "frameBytes": 6050}
// {"prefix": 3009, "width": 120, "height": 160, "encoding": "rgb555", "frameBytes": 38400, "littleEndian": false}
// {"prefix": 3011, "width": 75, "height": 75, "encoding": "rgb555", "frameBytes": 11250}
]
