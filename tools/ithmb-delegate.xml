<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE delegatemap [
  <!ELEMENT delegatemap (delegate)+>
  <!ELEMENT delegate EMPTY>
  <!ATTLIST delegate decode CDATA #REQUIRED
                     command CDATA #REQUIRED>
]>
<!--
  ImageMagick delegate for .ithmb files (iPod/iPhone thumbnail cache).

  Installation:
    cp ithmb-delegate.xml ~/.config/ImageMagick/delegates.xml
    (or append the <delegate> entry to your existing delegates.xml)

  Usage:
    convert ithmb:photo.ithmb out.png
    identify ithmb:photo.ithmb
    convert ithmb:photo.ithmb -resize 200x200 thumb.png

  Requires:
    - IthmbDecoder CLI in PATH (from dotnet run or published binary)
    - .NET 10 runtime (if using dotnet run)

  See tools/install-ithmb-magick.sh for automated setup.
-->
<delegatemap>
  <delegate decode="ITHMB"
            command="IthmbDecoder &quot;%M&quot; &quot;%o&quot;"/>
</delegatemap>
